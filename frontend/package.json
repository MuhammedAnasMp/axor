{
  "name": "axon",
  "private": true,
  "version": "1.0.82",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-dist-to-backend.cjs",
    "build-ui": "node ../updator/release.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron electron/main.cjs",
    "build-exe": "vite build && electron-builder --win && node scripts/copy-builds.cjs windows",
    "apk": "vite build && npx cap sync && cd android && .\\gradlew.bat assembleDebug && cd .. && node scripts/copy-builds.cjs android",
    "aapk": "npm run apk",
    "exe": "npm run build-exe",
    "both": "npm run apk && npm run exe"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/network": "^8.0.1",
    "@capgo/capacitor-updater": "^8.49.4",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "adm-zip": "^0.5.14",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.axon.app.desktop",
    "productName": "Axon",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/fav_icon.ico"
    },
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
